{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@cp/*": [
                "src/components/*"
            ],
            "@store/*": [
                "src/stores/*"
            ],
            "@/*": [
                "src/*"
            ]
        },
        "allowJs": true
    },
    "exclude": [
        "node_modules",
        "dist"
    ]
}